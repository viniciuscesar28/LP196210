#include <stdio.h>

int main() {
    int x, y;
    scanf("%d %d", &x, &y);
    
    int soma = 0;
    int menor = (x < y) ? x : y;
    int maior = (x > y) ? x : y;
    
    for (int i = menor + 1; i < maior; i++) {
        if (i % 2 != 0) {
            soma += i;
        }
    }
    
    printf("%d\n", soma);
    
    return 0;
}

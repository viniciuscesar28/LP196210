#include <stdio.h>

int main() {
    int valor, maior, posicao;
    int i;
    
    for(i = 1; i <= 100; i++) {
        scanf("%d", &valor);
        
        if(i == 1) {
            maior = valor;
            posicao = i;
        } else if(valor > maior) {
            maior = valor;
            posicao = i;
        }
    }
    
    printf("%d\n", maior);
    printf("%d\n", posicao);
    
    return 0;
}
#include <stdio.h>

int main() {
    int valores[100];
    int maior, posicao;
    int i;
    
    // Lê todos os 100 valores
    for(i = 0; i < 100; i++) {
        scanf("%d", &valores[i]);
    }
    
    // Encontra o maior valor e sua posição
    maior = valores[0];
    posicao = 1;
    
    for(i = 1; i < 100; i++) {
        if(valores[i] > maior) {
            maior = valores[i];
            posicao = i + 1;  // +1 porque a posição é 1-indexada
        }
    }
    
    printf("%d\n", maior);
    printf("%d\n", posicao);
    
    return 0;
}

#include <stdio.h>
#include <stdlib.h>

int main() {
    int a, b, c;
    int maiorAB, maiorABC;
    
    scanf("%d %d %d", &a, &b, &c);
    
    // Calcula o maior entre a e b usando a fórmula
    maiorAB = (a + b + abs(a - b)) / 2;
    
    // Calcula o maior entre maiorAB e c
    maiorABC = (maiorAB + c + abs(maiorAB - c)) / 2;
    
    printf("%d eh o maior\n", maiorABC);
    
    return 0;
}